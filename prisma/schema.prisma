generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RESTREINT
}

enum TypeCompte {
  ENSEIGNEMENT
  ASSOCIATION
  FEDERATION
  JARDIN_PRIVE
  ORGANISME_PUBLIC
}

enum TypeInteraction {
  APPEL
  EMAIL
  REUNION
}

enum StatutCampagne {
  BROUILLON
  ENVOYEE
}

enum StatutParticipant {
  CIBLE
  INVITE
  A_ACCEPTE
  A_PARTICIPE
  A_REFUSE
}

model User {
  id                           String        @id @default(cuid())
  prenom                       String?
  nom                          String
  email                        String        @unique
  password                     String
  role                         Role          @default(RESTREINT)
  actif                        Boolean       @default(true)
  consentementPartageContacts  Boolean       @default(false)
  consentementEmailsInfo       Boolean       @default(false)
  consentementMisAJourLe       DateTime?
  organisationId               String?
  organisation                 Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  interactions                 Interaction[]
  campagnes                    Campagne[]
  connexions                   LoginLog[]

  @@index([organisationId])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  nom       String
  role      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Organisation {
  @@map("Compte")
  id                String         @id @default(cuid())
  nom               String
  type              TypeCompte?
  membreSnhf        Boolean        @default(false)
  email             String?
  telephone         String?
  siteWeb           String?
  adresse           String?
  codePostal        String?
  ville             String?
  pays              String         @default("France")
  notes             String?
  parentId          String?
  parent            Organisation?  @relation("OrganisationHierarchie", fields: [parentId], references: [id], onDelete: SetNull)
  sousOrganisations Organisation[] @relation("OrganisationHierarchie")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  contacts          Contact[]
  interactions      Interaction[]
  vergers           Verger[]
  users             User[]

  @@index([nom])
  @@index([type])
  @@index([membreSnhf])
  @@index([parentId])
}

model Contact {
  id                    String                 @id @default(cuid())
  prenom                String
  nom                   String
  poste                 String?
  email                 String?
  telephone             String?
  adresse               String?
  codePostal            String?
  ville                 String?
  pays                  String                 @default("France")
  notes                 String?
  isMembre              Boolean                @default(false)
  dateAdhesion          DateTime?
  organisationId        String?                @map("compteId")
  organisation          Organisation?          @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  interactions          Interaction[]
  evenementParticipants EvenementParticipant[]
  vergers               Verger[]

  @@index([nom])
  @@index([prenom])
  @@index([email])
  @@index([organisationId])
  @@index([isMembre])
}

model Verger {
  id                        String        @id @default(cuid())
  nom                       String
  adresse                   String?
  codePostal                String?
  ville                     String?
  pays                      String        @default("France")
  contact                   String?
  proprietaire              String?
  exploitant                String?
  ouvertPublic              Boolean       @default(false)
  superficie                Float?
  sol                       String?
  ph                        Float?
  pluviometrie              Float?
  moisDeficit               String?
  responsableType           String?
  responsableOrganisationId String?
  responsableOrganisation   Organisation? @relation(fields: [responsableOrganisationId], references: [id], onDelete: SetNull)
  responsableContactId      String?
  responsableContact        Contact?      @relation(fields: [responsableContactId], references: [id], onDelete: SetNull)
  anneeCreation             Int?
  anneeConversion           Int?
  certifications            String?
  objectifs                 String?
  personnelEmployes         String?
  personnelBenevoles        String?
  activitesFormation        String?
  autresActivites           String?
  notes                     String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  arbres                    VergerArbre[]

  @@index([nom])
  @@index([responsableOrganisationId])
  @@index([responsableContactId])
}

model VergerArbre {
  id       String  @id @default(cuid())
  vergerId String
  verger   Verger  @relation(fields: [vergerId], references: [id], onDelete: Cascade)
  espece   String
  nbArbres Int?
  varietes String?
  formes   String?
  ageMoyen Int?
  ordre    Int     @default(0)

  @@index([vergerId])
}

model Interaction {
  id          String          @id @default(cuid())
  date        DateTime
  type        TypeInteraction
  sujet       String
  description String?
  organisationId String?        @map("compteId")
  organisation   Organisation?  @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([contactId])
  @@index([organisationId])
  @@index([userId])
  @@index([date])
}

model Campagne {
  id              String         @id @default(cuid())
  nom             String
  sujet           String
  contenu         String
  statut          StatutCampagne @default(BROUILLON)
  dateEnvoi       DateTime?
  nbDestinataires Int            @default(0)
  filtreOrganisationId String?        @map("filtreCompteId")
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  destinataires   CampagneDestinataire[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Evenement {
  id           String                 @id @default(cuid())
  titre        String
  date         DateTime
  lieu         String?
  lien         String?
  lienCr       String?
  objectifs    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  participants EvenementParticipant[]

  @@index([date])
}

model EvenementParticipant {
  id          String            @id @default(cuid())
  evenementId String
  evenement   Evenement         @relation(fields: [evenementId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  statut      StatutParticipant @default(CIBLE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([evenementId, contactId])
}

model CampagneDestinataire {
  id          String   @id @default(cuid())
  campagneId  String
  campagne    Campagne @relation(fields: [campagneId], references: [id], onDelete: Cascade)
  contactId   String?
  email       String
  nom         String
  envoye      Boolean  @default(false)
  erreur      String?

  @@index([campagneId])
  @@index([contactId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}
