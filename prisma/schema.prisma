generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBRE
}

enum TypeCompte {
  ENTREPRISE
  ASSOCIATION
  COLLECTIVITE
  PARTICULIER
  AUTRE
}

enum TypeInteraction {
  APPEL
  EMAIL
  REUNION
}

enum StatutCampagne {
  BROUILLON
  ENVOYEE
}

enum StatutParticipant {
  CIBLE
  INVITE
  A_ACCEPTE
  A_PARTICIPE
  A_REFUSE
}

model User {
  id           String        @id @default(cuid())
  nom          String
  email        String        @unique
  password     String
  role         Role          @default(MEMBRE)
  actif        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]
  campagnes    Campagne[]
}

model Compte {
  id           String        @id @default(cuid())
  nom          String
  type         TypeCompte    @default(AUTRE)
  email        String?
  telephone    String?
  adresse      String?
  codePostal   String?
  ville        String?
  pays         String        @default("France")
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contacts     Contact[]
  interactions Interaction[]
}

model Contact {
  id                    String                 @id @default(cuid())
  prenom                String
  nom                   String
  poste                 String?
  email                 String?
  telephone             String?
  adresse               String?
  codePostal            String?
  ville                 String?
  pays                  String                 @default("France")
  notes                 String?
  compteId              String?
  compte                Compte?                @relation(fields: [compteId], references: [id], onDelete: SetNull)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  interactions          Interaction[]
  evenementParticipants EvenementParticipant[]
}

model Interaction {
  id          String          @id @default(cuid())
  date        DateTime
  type        TypeInteraction
  sujet       String
  description String?
  compteId    String?
  compte      Compte?         @relation(fields: [compteId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Campagne {
  id              String         @id @default(cuid())
  nom             String
  sujet           String
  contenu         String
  statut          StatutCampagne @default(BROUILLON)
  dateEnvoi       DateTime?
  nbDestinataires Int            @default(0)
  filtreCompteId  String?
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  destinataires   CampagneDestinataire[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Evenement {
  id           String                 @id @default(cuid())
  titre        String
  date         DateTime
  lieu         String?
  objectifs    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  participants EvenementParticipant[]
}

model EvenementParticipant {
  id          String            @id @default(cuid())
  evenementId String
  evenement   Evenement         @relation(fields: [evenementId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  statut      StatutParticipant @default(CIBLE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([evenementId, contactId])
}

model CampagneDestinataire {
  id          String   @id @default(cuid())
  campagneId  String
  campagne    Campagne @relation(fields: [campagneId], references: [id], onDelete: Cascade)
  contactId   String
  email       String
  nom         String
  envoye      Boolean  @default(false)
  erreur      String?
}
