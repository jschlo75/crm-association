# Base de données PostgreSQL (ex: Neon, Supabase, Railway)
DATABASE_URL="postgresql://user:password@host:5432/crm_association"

# NextAuth - générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-aleatoire-tres-long"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend - optionnel, gratuit jusqu'à 3000 emails/mois)
# Sans cette clé, les campagnes sont marquées "envoyées" sans envoi réel (mode simulation)
# Créer un compte sur https://resend.com et générer une API key
RESEND_API_KEY=""
EMAIL_FROM="noreply@snhf.fr"
